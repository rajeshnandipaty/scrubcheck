# Optional. ScrubCheck's core (bundling + unit-cap checks) runs WITHOUT this key.
# Add a key only to turn on the "Explain with Claude" layer, which rewrites each
# finding in plain English. Cost is a fraction of a cent per claim.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Set to "custom" after you import the real CMS files, so the UI label reflects it.
SCRUBCHECK_DATASET=sample

# Optional: change the port if 3000 is taken.
# PORT=3001
